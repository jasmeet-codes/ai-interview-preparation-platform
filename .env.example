# ============================================================
# Copy this file to ".env" (same folder) and fill in your values.
# NEVER commit the real ".env" file to source control.
# ============================================================

# Flask secret key - used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# --- AI Provider ---------------------------------------------
# Paste your OpenAI API key here (get one at https://platform.openai.com/api-keys)
# If you leave this BLANK, the app automatically falls back to a built-in
# mock question bank / mock feedback engine so everything still works.
OPENAI_API_KEY=

# Model to use for question generation & answer evaluation
OPENAI_MODEL=gpt-4o-mini

# --- App settings ----------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True

# SQLite database file path (relative to project root)
DATABASE_PATH=instance/interview_prep.db

# Max resume upload size in MB
MAX_UPLOAD_MB=5
